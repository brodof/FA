[sub_resource type="GDScript" id="GDScript_xaxkt"]
script/source = "# res://scripts/duel/foot_contact_sensor.gd
# Godot 4.5.1
# Foot ground contact sensor:
# 1) Primary: contact manifold in _integrate_forces()
# 2) Fallback: short sole rays when manifold has 0 contacts
#    - can REQUIRE collision handshake (mask/layer) to avoid “fake grounded”

extends RigidBody2D
class_name FootContactSensor

@export var world_layer_index: int = 1
@export var accept_any_static: bool = true
@export var ground_normal_min_up: float = 0.18
@export var ignore_root: Node = null

@export_group(\"Fallback Rays (only when manifold contacts = 0)\")
@export var fallback_enable: bool = true
@export var fallback_ray_len: float = 10.0
@export var fallback_max_gap_px: float = 2.5
@export var fallback_require_mask_handshake: bool = true
@export var fallback_require_static: bool = true
@export var fallback_vy_max: float = 140.0
@export var fallback_points_local: PackedVector2Array = PackedVector2Array([
	Vector2(-6.0, 6.0), # heel-ish
	Vector2(6.0, 6.0) # toe-ish
])

@export_group(\"Stability Heuristic\")
@export var stab_ref_vx: float = 40.0
@export var stab_ref_vy: float = 80.0
@export var stab_ref_w: float = 6.0

# -------------------------
# Outputs consumed by controller
# -------------------------
var contact_count: int = 0
var accepted_count: int = 0
var grounded: bool = false
var contact_point_w: Vector2 = Vector2(NAN, NAN)
var contact_normal_w: Vector2 = Vector2(NAN, NAN)
var contact_y_raw: float = NAN
var contact_y: float = NAN
var stability01: float = 0.0

# -------------------------
# Debug counters
# -------------------------
var dbg_rej_ignored: int = 0
var dbg_rej_layer: int = 0
var dbg_rej_above: int = 0
var dbg_rej_updot: int = 0
var dbg_rej_mask: int = 0
var dbg_fallback_used: bool = false

func _ready() -> void:
	# Required for contact reporting on RigidBody2D
	contact_monitor = true
	max_contacts_reported = maxi(8, max_contacts_reported)

func _integrate_forces(state: PhysicsDirectBodyState2D) -> void:
	# Reset outputs
	contact_count = state.get_contact_count()
	accepted_count = 0
	grounded = false
	contact_point_w = Vector2(NAN, NAN)
	contact_normal_w = Vector2(NAN, NAN)
	contact_y_raw = NAN
	contact_y = NAN
	stability01 = 0.0

	dbg_rej_ignored = 0
	dbg_rej_layer = 0
	dbg_rej_above = 0
	dbg_rej_updot = 0
	dbg_rej_mask = 0
	dbg_fallback_used = false

	# Primary: manifold contacts
	var best_score: float = -1e18
	var world_bit: int = 1 << (maxi(1, world_layer_index) - 1)

	for i in range(contact_count):
		var col_obj: Object = state.get_contact_collider_object(i)
		if col_obj == null:
			continue

		if _is_ignored(col_obj):
			dbg_rej_ignored += 1
			continue

		if col_obj is CollisionObject2D:
			var co := col_obj as CollisionObject2D

			# Optional: verify collision handshake anyway (useful when debugging)
			if fallback_require_mask_handshake and not _handshake_ok(co):
				dbg_rej_mask += 1
				continue

			var ok_layer: bool = ((co.collision_layer & world_bit) != 0)
			if accept_any_static and (col_obj is StaticBody2D or col_obj is TileMap):
				ok_layer = true
			if not ok_layer:
				dbg_rej_layer += 1
				continue

		# World contact point
		var lp: Vector2 = state.get_contact_local_position(i)
		var p_w: Vector2 = global_transform * lp

		# Reject contacts clearly above the foot center (usually body collisions, not ground)
		# (Godot y+ is down, so \"above\" means smaller y)
		if p_w.y < (global_position.y - 2.0):
			dbg_rej_above += 1
			continue

		# World contact normal
		var ln: Vector2 = state.get_contact_local_normal(i)
		var n_w: Vector2 = global_transform.basis_xform(ln).normalized()

		# Use dot with Vector2.UP (0,-1): floor normal ~ (0,-1) => dot = 1
		var up_dot: float = n_w.dot(Vector2.UP)
		if up_dot < ground_normal_min_up:
			dbg_rej_updot += 1
			continue

		accepted_count += 1

		# Prefer the most \"ground-like\" contact:
		# high up_dot, and low point (larger y) as tie-breaker
		var score: float = up_dot * 1000.0 + p_w.y
		if score > best_score:
			best_score = score
			contact_point_w = p_w
			contact_normal_w = n_w
			contact_y_raw = p_w.y
			contact_y = p_w.y

	if accepted_count > 0:
		grounded = true
		_stability_from_velocities()
		return

	# Fallback: short rays (diagnostic + optional “functional” support)
	if fallback_enable:
		_try_fallback_rays()

func _try_fallback_rays() -> void:
	# Don’t use fallback at insane vertical speeds; it becomes noisy/meaningless
	if absf(linear_velocity.y) > fallback_vy_max:
		return

	var best_gap: float = 1e18
	var best_hit: Dictionary = {}

	for p_local in fallback_points_local:
		var from: Vector2 = global_transform * p_local
		var to: Vector2 = from + Vector2.DOWN * fallback_ray_len

		var q := PhysicsRayQueryParameters2D.create(from, to)
		q.collide_with_areas = false
		q.collide_with_bodies = true
		q.collision_mask = 0x7fffffff
		q.exclude = [get_rid()]

		var res: Dictionary = get_world_2d().direct_space_state.intersect_ray(q)
		if res.is_empty():
			continue

		var col: Object = res.get(\"collider\", null)
		if col == null:
			continue

		if _is_ignored(col):
			dbg_rej_ignored += 1
			continue

		if fallback_require_static and not (col is StaticBody2D or col is TileMap):
			# Avoid “grounding” on other ragdolls/weapons.
			continue

		if col is CollisionObject2D and fallback_require_mask_handshake:
			if not _handshake_ok(col as CollisionObject2D):
				dbg_rej_mask += 1
				continue

		var pos: Vector2 = res.get(\"position\", Vector2(NAN, NAN))
		var n: Vector2 = res.get(\"normal\", Vector2(NAN, NAN))

		var up_dot: float = n.normalized().dot(Vector2.UP)
		if up_dot < ground_normal_min_up:
			dbg_rej_updot += 1
			continue

		var gap: float = pos.y - from.y
		if gap < 0.0:
			continue
		if gap > fallback_max_gap_px:
			continue

		if gap < best_gap:
			best_gap = gap
			best_hit = res

	if best_hit.is_empty():
		return

	# Accept fallback “ground”
	dbg_fallback_used = true
	accepted_count = 1
	grounded = true

	contact_point_w = best_hit.get(\"position\", Vector2(NAN, NAN))
	contact_normal_w = best_hit.get(\"normal\", Vector2(NAN, NAN)).normalized()
	contact_y_raw = contact_point_w.y
	contact_y = contact_y_raw

	_stability_from_velocities()

func _handshake_ok(co: CollisionObject2D) -> bool:
	# Godot collision requires BOTH:
	# (self.mask hits other.layer) AND (other.mask hits self.layer)
	var A: bool = (collision_mask & co.collision_layer) != 0
	var B: bool = (co.collision_mask & collision_layer) != 0
	return A and B

func _is_ignored(obj: Object) -> bool:
	if ignore_root == null:
		return false
	if obj is Node:
		var n := obj as Node
		return (n == ignore_root) or ignore_root.is_ancestor_of(n)
	return false

func _stability_from_velocities() -> void:
	# Simple 0..1 heuristic: stable when slip, vertical motion, and spin are low.
	var sx: float = absf(linear_velocity.x) / maxf(1.0, stab_ref_vx)
	var sy: float = absf(linear_velocity.y) / maxf(1.0, stab_ref_vy)
	var sw: float = absf(angular_velocity) / maxf(0.01, stab_ref_w)
	var worst: float = maxf(sx, maxf(sy, sw))
	stability01 = clampf(1.0 - worst, 0.0, 1.0)
"

